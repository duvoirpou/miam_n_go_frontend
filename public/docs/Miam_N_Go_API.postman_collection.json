      "item": [
        {
          "name": "Lister les catégories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/categories", "host": ["{{base_url}}"], "path": ["categories"] },
            "description": "Route publique. Aucun token requis."
          },
          "response": []
        },
        {
