            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] },
            "description": "Route publique. Vérifie que l'API est disponible."
          },
          "response": []
        }
      ]
    },
    {
