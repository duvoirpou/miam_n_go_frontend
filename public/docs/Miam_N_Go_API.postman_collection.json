            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["categories", "{{category_id}}"]
            },
            "description": "Route publique. Aucun token requis."
          },
          "response": []
        }
      ]
    },
    {
      "name": "04. Partners",
      "description": "PUBLIC/CUSTOMER/PARTNER : lecture seule. ADMIN : gestion complète.",
      "item": [
        {
          "name": "Lister les partenaires",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/partners", "host": ["{{base_url}}"], "path": ["partners"] },
            "description": "Route publique. Aucun token requis."
          },
