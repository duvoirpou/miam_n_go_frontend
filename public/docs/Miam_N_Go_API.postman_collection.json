        },
        {
          "name": "Détail d'un partenaire",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/partners/{{partner_id}}",
              "host": ["{{base_url}}"],
              "path": ["partners", "{{partner_id}}"]
            },
            "description": "Route publique. Aucun token requis."
          },
          "response": []
        }
      ]
    },
    {
      "name": "05. Products",
      "description": "Catalogue produits. Lecture publique. Écriture réservée à PARTNER (ses propres produits uniquement) et ADMIN (tout).",
      "item": [
        {
          "name": "Lister les produits",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"] },
            "description": "Route publique. Aucun token requis."
          },
          "response": []
        },
        {
          "name": "Détail d'un produit",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["products", "{{product_id}}"]
            },
            "description": "Route publique. Aucun token requis."
          },
          "response": []
        },
        {
          "name": "Mes produits (PARTNER)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/my-products", "host": ["{{base_url}}"], "path": ["my-products"] },
            "description": "Route protégée. Nécessite un token PARTNER. Retourne uniquement les produits liés au(x) restaurant(s) du partenaire connecté (via `partner_users`)."
          },
          "response": []
        },
        {
          "name": "Créer un produit - cas autorisé (PARTNER)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label_products\": \"Burger God Favor\",\n  \"price\": 7000,\n  \"id_category\": 2,\n  \"id_partners\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"] },
            "description": "Route protégée. Un PARTNER ne peut créer un produit que pour son propre `id_partners`. Réponse attendue : `201 Created`."
          },
          "response": []
        },
        {
          "name": "Créer un produit - cas interdit (autre partenaire)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label_products\": \"Produit interdit\",\n  \"price\": 5000,\n  \"id_category\": 1,\n  \"id_partners\": 2\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"] },
            "description": "Exemple de rejet de sécurité. Un token PARTNER tentant de créer un produit pour un `id_partners` qui ne lui appartient pas reçoit :\n\n```\n403 Forbidden\n{\n  \"success\": false,\n  \"message\": \"Accès refusé. Vous ne pouvez créer un produit que pour votre propre partenaire.\"\n}\n```"
          },
          "response": []
        },
        {
          "name": "Modifier un produit",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label_products\": \"Burger God Favor - Maxi\",\n  \"price\": 7500\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["products", "{{product_id}}"]
            },
            "description": "Route protégée. PARTNER : uniquement ses propres produits. ADMIN : tous les produits."
          },
          "response": []
        },
        {
          "name": "Supprimer un produit",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["products", "{{product_id}}"]
            },
            "description": "Route protégée. PARTNER : uniquement ses propres produits. ADMIN : tous les produits."
          },
          "response": []
        }
      ]
    },
    {
      "name": "06. Customers",
      "description": "ADMIN : tous les clients. PARTNER : uniquement les clients ayant commandé ses produits. CUSTOMER : uniquement son propre profil.",
      "item": [
        {
          "name": "Lister les clients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/customers", "host": ["{{base_url}}"], "path": ["customers"] },
            "description": "Route protégée. Le résultat dépend du rôle : ADMIN voit tout, PARTNER voit les clients ayant commandé ses produits, CUSTOMER voit son propre profil."
          },
          "response": []
        },
        {
          "name": "Détail d'un client",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/customers/{{customer_id}}",
              "host": ["{{base_url}}"],
              "path": ["customers", "{{customer_id}}"]
            },
            "description": "Route protégée. Accès restreint selon le rôle (voir synthèse des droits)."
          },
          "response": []
        },
        {
          "name": "Modifier un client",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name_customers\": \"Franck\",\n  \"last_name_customers\": \"Kianguebeni\",\n  \"phone_customers\": \"066000002\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/customers/{{customer_id}}",
              "host": ["{{base_url}}"],
              "path": ["customers", "{{customer_id}}"]
            },
            "description": "Route protégée. CUSTOMER : uniquement son propre profil. ADMIN : tous les profils."
          },
          "response": []
        },
        {
          "name": "Supprimer un client",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/customers/{{customer_id}}",
              "host": ["{{base_url}}"],
              "path": ["customers", "{{customer_id}}"]
            },
            "description": "Route protégée. Réservé généralement à ADMIN."
          },
          "response": []
        }
      ]
    },
    {
      "name": "07. Orders",
      "description": "ADMIN : toutes les commandes. PARTNER : commandes contenant au moins un de ses produits. CUSTOMER : ses propres commandes, créées avec son token (id_customers déduit automatiquement).",
      "item": [
        {
          "name": "Lister les commandes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/orders", "host": ["{{base_url}}"], "path": ["orders"] },
            "description": "Route protégée. Portée selon rôle : ADMIN = toutes, PARTNER = commandes contenant ses produits, CUSTOMER = ses commandes."
          },
          "response": []
        },
        {
          "name": "Créer une commande (CUSTOMER)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"products\": [\n    {\n      \"id_products\": 1,\n      \"quantity\": 2\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/orders", "host": ["{{base_url}}"], "path": ["orders"] },
            "description": "Route protégée, réservée au rôle CUSTOMER. Le client est identifié automatiquement via le token : NE PAS envoyer `id_customers`.\n\nStatut initial recommandé après création : `status_order = PENDING`, `status_payment = PENDING`, `status_delivery = PENDING`."
          },
          "response": []
        },
        {
          "name": "Détail d'une commande",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/orders/{{order_id}}",
              "host": ["{{base_url}}"],
              "path": ["orders", "{{order_id}}"]
            },
            "description": "Route protégée. Visibilité selon rôle (voir synthèse des droits)."
          },
          "response": []
        },
        {
          "name": "Mettre à jour le statut d'une commande",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status_order\": \"CONFIRMED\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/orders/{{order_id}}",
              "host": ["{{base_url}}"],
              "path": ["orders", "{{order_id}}"]
            },
            "description": "Route protégée. ADMIN modifie les statuts globaux, PARTNER met à jour certains statuts opérationnels sur les commandes contenant ses produits.\n\n**Valeurs autorisées pour `status_order`** : PENDING, CONFIRMED, PREPARING, READY, COMPLETED, CANCELLED, REJECTED.\n\nWorkflow recommandé : `PENDING -> CONFIRMED -> PREPARING -> READY -> COMPLETED`.\nCas alternatifs : `PENDING -> CANCELLED`, `PENDING -> REJECTED`."
          },
          "response": []
        },
        {
          "name": "Supprimer une commande",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/orders/{{order_id}}",
              "host": ["{{base_url}}"],
              "path": ["orders", "{{order_id}}"]
            },
            "description": "Route protégée. Réservé généralement à ADMIN."
          },
          "response": []
        }
      ]
    },
    {
      "name": "08. Payments",
      "description": "ADMIN : tous les paiements. CUSTOMER : peut payer uniquement ses propres commandes. PARTNER : lecture seule sur les paiements liés à ses produits (ne peut pas créer de paiement -> 403).",
      "item": [
        {
          "name": "Lister les paiements",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/payments", "host": ["{{base_url}}"], "path": ["payments"] },
            "description": "Route protégée. Portée selon rôle : ADMIN = tous, CUSTOMER = paiements de ses commandes, PARTNER = paiements liés à ses produits."
          },
          "response": []
        },
        {
          "name": "Créer un paiement - Mobile Money (CUSTOMER)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_orders\": 1,\n  \"type\": \"MOBILE_MONEY\",\n  \"phone_payment\": \"066000000\",\n  \"transaction\": \"TXN-CUST-001\",\n  \"token\": \"TOKEN-CUST-001\",\n  \"response\": \"OK\",\n  \"status_transaction\": \"SUCCESS\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/payments", "host": ["{{base_url}}"], "path": ["payments"] },
            "description": "Route protégée, réservée à CUSTOMER (paiement de sa propre commande) ou ADMIN. `phone_payment` trace le numéro utilisé pour le paiement Mobile Money."
          },
          "response": []
        },
        {
          "name": "Créer un paiement - Cash on delivery (CUSTOMER)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_orders\": 1,\n  \"type\": \"CASH_ON_DELIVERY\",\n  \"phone_payment\": \"066000000\",\n  \"transaction\": \"CASH-001\",\n  \"response\": \"OK\",\n  \"status_transaction\": \"SUCCESS\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/payments", "host": ["{{base_url}}"], "path": ["payments"] },
            "description": "Paiement à la livraison. À la création de la commande : `status_payment = PENDING`. Après encaissement effectif : `status_payment = PAID`."
          },
          "response": []
        },
        {
          "name": "Créer un paiement - cas interdit (PARTNER)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_orders\": 1,\n  \"type\": \"MOBILE_MONEY\",\n  \"phone_payment\": \"066000000\",\n  \"transaction\": \"TXN-PARTNER-001\",\n  \"response\": \"OK\",\n  \"status_transaction\": \"SUCCESS\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/payments", "host": ["{{base_url}}"], "path": ["payments"] },
            "description": "Test validé côté doc source : un token PARTNER tentant de créer un paiement reçoit :\n\n```\n403 Forbidden\n{\n  \"success\": false,\n  \"message\": \"Accès refusé. Un partenaire ne peut pas créer un paiement.\"\n}\n```"
          },
          "response": []
        },
        {
          "name": "Détail d'un paiement",
